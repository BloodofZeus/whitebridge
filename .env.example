# ─── Required ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, Railway, etc.)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Express session secret — use a long random string in production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=replace-with-a-long-random-secret

# ─── Optional ─────────────────────────────────────────────────────────────────
# Port the server listens on (default: 5000)
PORT=5000

# Email sending via Resend (https://resend.com)
# Used for transactional emails (password reset, notifications, etc.)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Alternative email API key name (also checked if RESEND_API_KEY is absent)
EMAIL_API_KEY=

# Frontend base URL — used in password-reset email links
# Set to your production domain (e.g. https://finora.yourdomain.com)
FRONTEND_URL=https://your-app.vercel.app

# Allowed CORS origin in production — restricts cross-origin API access
# Set to the same value as FRONTEND_URL (e.g. https://finora.yourdomain.com)
# Leave unset in development (all origins are allowed when NODE_ENV != production)
ALLOWED_ORIGIN=https://your-app.vercel.app

# ─── Twilio (SMS notifications) ───────────────────────────────────────────────
# Twilio credentials are stored in the Admin Settings panel inside the app.
# You do NOT need to set them here — they are persisted to the database.
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ─── Production-only ──────────────────────────────────────────────────────────
# Automatically set by Vercel/Railway/Render — no need to set manually
# NODE_ENV=production
